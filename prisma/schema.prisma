generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  type        String
  chapter     String?  @db.VarChar(255)
  level       Int?
  mastery     String?
  understood  Boolean  @default(false)
  exam        Boolean  @default(false)
  confidence  Int?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("subjects")
}

model HabitEntry {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  mathematics     Boolean  @default(false)
  philosophy      Boolean  @default(false)
  english         Boolean  @default(false)
  informatics     Boolean  @default(false)
  gym             Boolean  @default(false)
  sleep           Boolean  @default(false)
  water           Boolean  @default(false)
  organization    Boolean  @default(false)
  personalProject Boolean  @default(false)
  score           Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("habit_entries")
  @@index([date])
}

model CalendarEvent {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  type      String
  date      DateTime
  domain    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("calendar_events")
  @@index([date])
  @@index([type])
}

model Goal {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  domain      String
  progress    Int      @default(0)
  deadline    DateTime?
  status      String   @default("Not started")
  description String?  @db.Text
  tasks       Task[]   @relation("GoalTasks")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("goals")
  @@index([domain])
  @@index([status])
}

model Task {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  dueDate     DateTime?
  status      String   @default("Not started")
  domain      String?
  goal        Goal?    @relation("GoalTasks", fields: [goalId], references: [id], onDelete: SetNull)
  goalId      Int?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
  @@index([dueDate])
  @@index([status])
  @@index([goalId])
}
